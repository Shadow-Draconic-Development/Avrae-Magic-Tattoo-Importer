            ch.create_cc_nx(
                name="Absorbing Tattoo",
                minVal="0",
                maxVal="1",
                reset="long",
                dispType="bubble",
                reset_to="1",
                title="Absorbing Tattoo",
                desc="Produced by a special needle, this magic tattoo features designs that emphasize one color.",
                initial_value="1"
            )

